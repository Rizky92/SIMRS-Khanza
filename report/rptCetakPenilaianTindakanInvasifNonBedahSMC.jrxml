	<queryString language="SQL">
		<![CDATA[select s.no_rawat,
    s.tanggal,
    s.nip,
    s.diagnosa,
    s.rencana_tindakan,
    s.status_fungsional,
    s.keluhan_utama,
    s.status_psiko,
    s.ket_psiko,
    s.rpd,
